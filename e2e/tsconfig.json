{
  "compilerOptions": {
    "lib": ["es2020"],
    "target": "es6",
    "module": "commonjs",
    "moduleResolution": "node16",
    "declaration": true,
    "sourceMap": true,
    "strict": true,
    "noImplicitAny": true,
    "allowSyntheticDefaultImports": true,
    "useUnknownInCatchVariables": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "rootDir": ".."
  },
  "include": ["."]
}
