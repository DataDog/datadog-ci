  "devDependencies": {
    "@aws-sdk/client-cloudwatch-logs": "3.981.0",
    "@aws-sdk/client-iam": "3.981.0",
    "@aws-sdk/client-sfn": "3.981.0",
    "@datadog/datadog-ci-base": "workspace:*",
    "aws-sdk-client-mock": "4.1.0",
    "deep-object-diff": "1.1.9"
