{
  "name": "@datadog/datadog-ci-plugin-stepfunctions",
  "version": "5.11.0",
  "description": "Datadog CI plugin for `stepfunctions` commands",
  "license": "Apache-2.0",
  "keywords": [
    "datadog",
    "datadog-ci",
    "plugin"
  ],
  "homepage": "https://github.com/DataDog/datadog-ci/tree/master/packages/plugin-stepfunctions",
  "repository": {
    "type": "git",
    "url": "https://github.com/DataDog/datadog-ci.git",
    "directory": "packages/plugin-stepfunctions"
  },
  "main": "dist/bundle.js",
  "exports": {
    "./package.json": "./package.json",
    ".": "./dist/bundle.js"
  },
  "files": [
    "dist/bundle.js",
