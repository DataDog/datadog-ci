{
  "name": "@datadog/datadog-ci",
  "version": "5.11.0",
  "description": "Use Datadog from your CI.",
  "license": "Apache-2.0",
  "keywords": [
    "datadog",
    "datadog-ci"
  ],
  "homepage": "https://github.com/DataDog/datadog-ci",
  "repository": {
    "type": "git",
    "url": "https://github.com/DataDog/datadog-ci.git",
    "directory": "packages/datadog-ci"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": "dist/bundle.mjs",
  "main": "dist/bundle.mjs",
  "types": "dist/cli.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": "./dist/bundle.mjs"
  },
  "files": [
    "dist/bundle.mjs",
    "dist/bundle.mjs.map",
    "dist/bundle.mjs.LEGAL.txt",
    "dist/cli.d.ts",
    "README",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "yarn package:clean; yarn package:build",
    "lint": "yarn package:lint",
    "prepack": "yarn package:clean-dist && yarn bundle:npm && yarn package:bundle:npm-dts"
  },
  "devDependencies": {
    "@datadog/datadog-ci-base": "workspace:*",
    "@datadog/datadog-ci-plugin-coverage": "workspace:*",
    "@datadog/datadog-ci-plugin-deployment": "workspace:*",
    "@datadog/datadog-ci-plugin-dora": "workspace:*",
    "@datadog/datadog-ci-plugin-gate": "workspace:*",
    "@datadog/datadog-ci-plugin-junit": "workspace:*",
    "@datadog/datadog-ci-plugin-sarif": "workspace:*",
    "@datadog/datadog-ci-plugin-sbom": "workspace:*",
    "@types/jest": "29.5.3",
    "clipanion": "3.2.1",
    "typanion": "3.14.0"
  }
}
