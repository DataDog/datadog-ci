{
  "name": "@datadog/datadog-ci-plugin-junit",
  "version": "5.12.0",
  "description": "Datadog CI plugin for `junit` commands",
  "license": "Apache-2.0",
  "keywords": [
    "datadog",
    "datadog-ci",
    "plugin"
  ],
  "homepage": "https://github.com/DataDog/datadog-ci/tree/master/packages/plugin-junit",
  "repository": {
    "type": "git",
    "url": "https://github.com/DataDog/datadog-ci.git",
    "directory": "packages/plugin-junit"
  },
  "main": "dist/bundle.js",
  "exports": {
    "./package.json": "./package.json",
    ".": "./dist/bundle.js",
    "./commands/*": {
      "development": "./src/commands/*.ts",
      "default": "./dist/commands/*.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.js.LEGAL.txt",
    "dist/**/*.d.ts",
    "README",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "yarn package:clean; yarn package:build",
    "lint": "yarn package:lint",
    "prepack": "yarn package:clean-dist; yarn package:bundle:npm"
  },
  "devDependencies": {
    "@datadog/datadog-ci-base": "workspace:*",
    "axios": "1.13.5",
    "chalk": "3.0.0",
    "fast-xml-parser": "5.5.9",
    "form-data": "4.0.4",
    "upath": "2.0.1",
    "uuid": "9.0.1"
  }
}
