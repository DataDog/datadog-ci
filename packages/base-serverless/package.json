{
  "name": "@datadog/datadog-ci-base-serverless",
  "version": "5.17.0",
  "description": "Shared serverless helpers for Datadog CI plugins",
  "license": "Apache-2.0",
  "keywords": [
    "datadog",
    "datadog-ci"
  ],
  "homepage": "https://github.com/DataDog/datadog-ci/tree/master/packages/base-serverless",
  "repository": {
    "type": "git",
    "url": "https://github.com/DataDog/datadog-ci.git",
    "directory": "packages/base-serverless"
  },
  "main": "dist/index.js",
  "exports": {
    "./package.json": "./package.json",
    "./helpers/serverless/*": {
      "development": "./src/helpers/serverless/*.ts",
      "default": "./dist/helpers/serverless/*.js"
    }
  },
  "files": [
    "dist/**/*",
    "LICENSE"
  ],
  "scripts": {
    "build": "yarn package:clean; yarn package:build",
    "lint": "yarn package:lint",
    "prepack": "yarn package:clean-dist"
  },
  "dependencies": {
    "@datadog/datadog-ci-base": "workspace:*",
    "chalk": "3.0.0",
    "clipanion": "3.2.1",
    "form-data": "4.0.4",
    "jest-diff": "30.2.0",
    "upath": "2.0.1"
  },
  "private": true
}
