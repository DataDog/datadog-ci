{
  "name": "@datadog/datadog-ci-plugin-container-app",
  "version": "5.11.0",
  "description": "Datadog CI plugin for `container-app` commands",
  "license": "Apache-2.0",
  "keywords": [
    "datadog",
    "datadog-ci",
    "plugin"
  ],
  "homepage": "https://github.com/DataDog/datadog-ci/tree/master/packages/plugin-container-app",
  "repository": {
    "type": "git",
    "url": "https://github.com/DataDog/datadog-ci.git",
    "directory": "packages/plugin-container-app"
  },
  "main": "dist/bundle.js",
  "exports": {
    "./package.json": "./package.json",
    ".": "./dist/bundle.js"
  },
  "files": [
    "dist/*.js",
    "dist/*.js.map",
    "dist/*.js.LEGAL.txt",
    "dist/**/*.d.ts",
    "README",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "yarn package:clean; yarn package:build",
    "lint": "yarn package:lint",
    "prepack": "yarn package:clean && yarn package:build && yarn package:clean-dist && yarn package:bundle:npm"
  },
  "devDependencies": {
    "@azure/arm-appcontainers": "3.0.0",
    "@azure/arm-resources": "6.1.0",
    "@azure/identity": "4.10.1",
    "@datadog/datadog-ci-base": "workspace:*",
    "chalk": "3.0.0"
  }
}
