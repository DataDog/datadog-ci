{
  "name": "@datadog/datadog-ci-plugin-synthetics",
  "version": "5.12.0",
  "description": "Datadog CI plugin for `synthetics` commands",
  "license": "Apache-2.0",
  "keywords": [
    "datadog",
    "datadog-ci",
    "plugin"
  ],
  "homepage": "https://github.com/DataDog/datadog-ci/tree/master/packages/plugin-synthetics",
  "repository": {
    "type": "git",
    "url": "https://github.com/DataDog/datadog-ci.git",
    "directory": "packages/plugin-synthetics"
  },
  "main": "dist/bundle.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/bundle.js"
    },
    "./commands/*": {
      "development": "./src/commands/*.ts",
      "default": "./dist/commands/*.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.js.LEGAL.txt",
    "dist/index.d.ts",
    "README",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "yarn package:clean; yarn package:build",
    "lint": "yarn package:lint",
    "prepack": "yarn package:clean-dist; yarn package:bundle:npm"
  },
  "devDependencies": {
    "@datadog/datadog-ci-base": "workspace:*",
    "@types/deep-extend": "0.4.31",
    "@types/set-value": "4.0.3",
    "@types/ssh2": "1.15.5",
    "@types/sshpk": "1.10.7",
    "@types/ws": "7.2.9",
    "@types/xml2js": "0.4.14",
    "axios": "1.13.5",
    "chalk": "3.0.0",
    "debug": "4.4.1",
    "deep-extend": "0.6.0",
    "fast-levenshtein": "3.0.0",
    "get-value": "4.0.1",
    "ora": "5.4.1",
    "set-value": "4.1.0",
    "ssh2": "1.17.0",
    "sshpk": "1.16.1",
    "upath": "2.0.1",
    "ws": "7.5.10",
    "xml2js": "0.5.0",
    "yamux-js": "0.1.2"
  }
}
