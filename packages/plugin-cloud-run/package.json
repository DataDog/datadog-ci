{
  "name": "@datadog/datadog-ci-plugin-cloud-run",
  "version": "5.12.1",
  "description": "Datadog CI plugin for `cloud-run` commands",
  "license": "Apache-2.0",
  "keywords": [
    "datadog",
    "datadog-ci",
    "plugin"
  ],
  "homepage": "https://github.com/DataDog/datadog-ci/tree/master/packages/plugin-cloud-run",
  "repository": {
    "type": "git",
    "url": "https://github.com/DataDog/datadog-ci.git",
    "directory": "packages/plugin-cloud-run"
  },
  "main": "dist/bundle.js",
  "exports": {
    "./package.json": "./package.json",
    ".": "./dist/bundle.js",
    "./commands/*": {
      "development": "./src/commands/*.ts",
      "default": "./dist/commands/*.js"
    }
  },
  "files": [
    "dist/bundle.js",
    "dist/bundle.js.map",
    "dist/bundle.js.LEGAL.txt",
    "dist/bundle.d.ts",
    "dist/commands/*.js",
    "README",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "yarn package:clean; yarn package:build",
    "lint": "yarn package:lint",
    "prepack": "yarn package:clean-dist; yarn package:bundle:npm"
  },
  "devDependencies": {
    "@datadog/datadog-ci-base": "workspace:*",
    "@google-cloud/logging": "11.2.0",
    "@google-cloud/run": "3.0.0",
    "chalk": "3.0.0",
    "google-auth-library": "10.2.1",
    "inquirer": "8.2.7",
    "inquirer-checkbox-plus-prompt": "1.4.2",
    "ora": "5.4.1",
    "upath": "2.0.1"
  }
}
